---
---

<div id="pw-overlay">
  <h2>Fumiko Cho</h2>
  <div class="pw-form">
    <input type="password" id="pw-input" placeholder="password" autocomplete="off" />
    <p class="pw-error" id="pw-error"></p>
    <button id="pw-submit">Enter</button>
  </div>
</div>

<style>
  #pw-overlay {
    position: fixed;
    inset: 0;
    background: var(--color-bg);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }

  #pw-overlay h2 {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .pw-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .pw-form input {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.15em;
    border: none;
    border-bottom: 1px solid var(--color-text);
    outline: none;
    padding: 8px 0;
    width: 200px;
    text-align: center;
    background: transparent;
  }

  .pw-form input::placeholder {
    color: var(--color-border);
    letter-spacing: 0.1em;
  }

  .pw-form button {
    font-family: var(--font-main);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: none;
    border: 1px solid var(--color-text);
    padding: 10px 32px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .pw-form button:hover {
    background: var(--color-text);
    color: #ffffff;
  }

  .pw-error {
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: #999;
    min-height: 16px;
  }
</style>

<script>
  // パスワードを変更する場合は、ブラウザのコンソールで以下を実行してハッシュを取得:
  // crypto.subtle.digest('SHA-256', new TextEncoder().encode('新しいパスワード'))
  //   .then(b => console.log([...new Uint8Array(b)].map(x => x.toString(16).padStart(2,'0')).join('')))
  const PASSWORD_HASH = '616384da8ed2fb86db3462ec827bc433256324e323a2438f48ae32930e707065';
  const SESSION_KEY = 'fc_auth';

  async function sha256(text: string): Promise<string> {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(text));
    return [...new Uint8Array(buf)].map(x => x.toString(16).padStart(2, '0')).join('');
  }

  const overlay = document.getElementById('pw-overlay') as HTMLElement;
  const input = document.getElementById('pw-input') as HTMLInputElement;
  const error = document.getElementById('pw-error') as HTMLElement;
  const btn = document.getElementById('pw-submit') as HTMLButtonElement;

  async function checkPassword() {
    const hash = await sha256(input.value);
    if (hash === PASSWORD_HASH) {
      sessionStorage.setItem(SESSION_KEY, 'true');
      overlay.style.display = 'none';
    } else {
      error.textContent = 'incorrect password';
      input.value = '';
    }
  }

  btn.addEventListener('click', checkPassword);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') checkPassword();
  });

  if (sessionStorage.getItem(SESSION_KEY) === 'true') {
    overlay.style.display = 'none';
  }
</script>
