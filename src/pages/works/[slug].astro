---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PasswordOverlay from '../../components/PasswordOverlay.astro';
import { works } from '../../data/works';
import { Image } from 'astro:assets';

const imagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.{jpeg,jpg,png,gif}', { eager: true });
const getImage = (path: string | undefined) => path ? imagesGlob[`/src/assets${path}`]?.default : null;

export function getStaticPaths() {
  return works.map((work) => ({ params: { slug: work.slug } }));
}

const { slug } = Astro.params;
const work = works.find((w) => w.slug === slug)!;
---

<Layout title={`${work.title} — Fumiko Cho`} description={work.title}>

  <!-- ヘッダー部分: 白背景 -->
  <div class="site-wrapper">
    <SiteHeader showClose navOnly />

    <section class="work-detail-header-section">
      <div class="work-detail-header">
        <h2 class="work-detail-title">{work.title}</h2>
        <div class="work-detail-meta">
          {work.tags && work.tags.length > 0 && (
            <p class="work-detail-tags">{work.tags.join(' , ')}</p>
          )}
          {work.date && (
            <p class="work-detail-pagination">{work.date}</p>
          )}
        </div>
      </div>
    </section>
  </div>

  <!-- 画像部分: #E7E6E4 背景（全幅） -->
  <div class="work-images-bg">
    <div class="site-wrapper">

      {(work.desktop || work.mobile) ? (
        <!-- webレイアウト: 幅によってdesktop/mobile画像を切り替え -->
        <div class="work-web-inner">
          {work.cover && (
            <div class="work-web-hero">
              <Image src={getImage(work.cover)!} alt={work.title} loading="eager" fetchpriority="high" />
            </div>
          )}
          <picture class="work-web-image">
            {work.mobile && <source media="(max-width: 600px)" srcset={getImage(work.mobile)?.src} />}
            {work.desktop && <Image src={getImage(work.desktop)!} alt={work.title} loading="lazy" />}
          </picture>
        </div>
      ) : (
        <!-- エディトリアルレイアウト -->
        <div class="work-images-inner">
          {work.cover && (
            <div class="work-detail-hero">
              <Image src={getImage(work.cover)!} alt={work.title} loading="eager" fetchpriority="high" />
            </div>
          )}
          {work.images && work.images.length > 0 && (
            <div class="work-detail-grid">
              {work.images.map((src, idx) => (
                <div class="work-detail-sub">
                  <Image src={getImage(src)!} alt={work.title} loading={idx < 2 && !work.cover ? 'eager' : 'lazy'} fetchpriority={idx < 2 && !work.cover ? 'high' : 'auto'} />
                </div>
              ))}
            </div>
          )}
        </div>
      )}

    </div>
  </div>

  <div class="site-wrapper">
    <SiteFooter />
  </div>

  <PasswordOverlay />
</Layout>

<style>
  .work-detail-header-section {
    margin-top: 100px;
    padding-bottom: 100px;
  }

  @media (max-width: 600px) {
    .work-detail-header-section {
      padding-bottom: 110px;
    }
  }

  .work-detail-header {
    position: relative;
  }

  .work-detail-title {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #000000;
    margin-bottom: 40px;
  }

  .work-detail-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .work-detail-tags {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #727171;
  }

  .work-detail-pagination {
    position: absolute;
    top: 0;
    right: 0;
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--color-subtitle);
    white-space: nowrap;
    padding-top: 2px;
  }

  @media (max-width: 600px) {
    .work-detail-title {
      margin-bottom: 44px;
    }
    .work-detail-pagination {
      position: static;
      padding-top: 0;
    }
  }

  /* 画像セクション: 全幅グレー背景 */
  .work-images-bg {
    background: #E7E6E4;
    width: 100%;
  }

  .work-images-inner {
    padding: 100px 0 100px;
  }

  .work-detail-hero {
    width: 100%;
    margin: 0 auto 100px;
  }

  .work-detail-hero img {
    height: 680px;
    width: auto;
    margin: 0 auto;
    display: block;
  }

  /* サブ画像: 2列グリッド・横長（見開き比率） */
  .work-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .work-detail-sub img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 600px) {
    .work-images-inner {
      padding: 80px 0 80px;
    }

    .work-detail-hero {
      width: 100%;
      margin-bottom: 80px;
    }

    .work-detail-hero img {
      width: 100%;
      height: auto;
    }

    .work-detail-grid {
      grid-template-columns: 1fr;
    }
  }

  /* webレイアウト */
  .work-web-inner {
    padding: 100px 0 100px;
  }

  /* デバイスモックアップ（影は画像に含まれる） */
  .work-web-hero {
    width: 84%;
    margin: 0 auto;
  }

  .work-web-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 600px) {
    .work-web-inner {
      padding: 80px 0 80px;
    }
    
    .work-web-hero {
      width: 100%;
    }
  }

  .work-web-image {
    display: block;
  }

  .work-web-image img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
