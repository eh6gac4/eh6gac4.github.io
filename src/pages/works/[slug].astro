---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PasswordOverlay from '../../components/PasswordOverlay.astro';
import { works } from '../../data/works';

export function getStaticPaths() {
  return works.map((work) => ({ params: { slug: work.slug } }));
}

const { slug } = Astro.params;
const index = works.findIndex((w) => w.slug === slug);
const work = works[index];
const total = works.length;
const current = index + 1;
---

<Layout title={`${work.title} — Fumiko Cho`}>

  <!-- ヘッダー部分: 白背景 -->
  <div class="site-wrapper">
    <SiteHeader showClose navOnly />

    <section class="work-detail-header-section">
      <div class="work-detail-header">
        <div>
          <h2 class="work-detail-title">{work.title}</h2>
          {work.tags && work.tags.length > 0 && (
            <p class="work-detail-tags">{work.tags.join(', ')}</p>
          )}
        </div>
        {work.date && (
          <p class="work-detail-pagination">{work.date}</p>
        )}
      </div>
    </section>
  </div>

  <!-- 画像部分: #E7E6E4 背景（全幅） -->
  <div class="work-images-bg">
    <div class="site-wrapper">
      <div class="work-images-inner">

        {work.cover && (
          <div class="work-detail-hero">
            <img src={work.cover} alt={work.title} />
          </div>
        )}

        {work.images && work.images.length > 0 && (
          <div class="work-detail-grid">
            {work.images.map((src) => (
              <div class="work-detail-sub">
                <img src={src} alt={work.title} />
              </div>
            ))}
          </div>
        )}

      </div>
    </div>
  </div>

  <div class="site-wrapper">
    <SiteFooter />
  </div>

  <PasswordOverlay />
</Layout>

<style>
  .work-detail-header-section {
    margin-top: 96px;
    padding-bottom: 60px;
  }

  .work-detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .work-detail-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin-bottom: 40px;
  }

  .work-detail-tags {
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: var(--color-subtitle);
  }

  .work-detail-pagination {
    font-size: 10px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--color-subtitle);
    white-space: nowrap;
    padding-top: 2px;
  }

  /* 画像セクション: 全幅グレー背景 */
  .work-images-bg {
    background: #E7E6E4;
    width: 100%;
  }

  .work-images-inner {
    padding: 60px 0 80px;
  }

  .work-detail-hero {
    margin-bottom: 32px;
  }

  .work-detail-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* サブ画像: 2列グリッド・横長（見開き比率） */
  .work-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .work-detail-sub img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 600px) {
    .work-detail-hero {
      width: 100%;
    }

    .work-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
