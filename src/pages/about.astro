---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import PasswordOverlay from '../components/PasswordOverlay.astro';
---

<Layout title="About — Fumiko Cho">
  <div class="site-wrapper">
    <SiteHeader showClose />

    <main class="about">
      <p class="about-bio">
        Freelance since 2019.<br />
        Primarily works on graphic and web design for kids, beauty, and fashion.
      </p>
    </main>

    <footer>
      <p>© Fumiko Cho</p>
    </footer>
  </div>

  <PasswordOverlay />
</Layout>

<style>
  .about {
    margin-top: 80px;
    margin-bottom: 150px;
  }

  .about-bio {
    font-size: 12px;
    font-weight: 300;
    line-height: 1.9;
    color: var(--color-subtitle);
  }
</style>
